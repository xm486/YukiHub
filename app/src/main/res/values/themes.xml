<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/yh_bg</item>
        <item name="android:colorAccent">@color/yh_primary</item>
        <item name="colorPrimary">@color/yh_primary</item>
        <item name="colorPrimaryVariant">@color/yh_bg_2</item>
        <item name="colorOnPrimary">@color/yh_bg</item>
    </style>

    <style name="AppTheme" parent="Base.AppTheme" />

    <style name="Theme.YukiHub.Kirikiroid2" parent="android:style/Theme.Material.NoActionBar.Fullscreen">
        <item name="android:backgroundDimAmount">1.0</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowDisablePreview">true</item>
    </style>

    <!-- Shared view styles are defined in values/styles.xml. -->
</resources>