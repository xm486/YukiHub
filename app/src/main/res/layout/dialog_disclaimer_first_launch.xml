<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@drawable/bg_auth_dialog">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="18dp"
        android:paddingEnd="22dp"
        android:paddingBottom="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:background="@drawable/bg_logo_circle"
                android:text="Y"
                android:textColor="#F4F7FF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="欢迎使用 YukiHub"
                    android:textColor="@color/yh_text"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="首次启动前，请确认免责声明"
                    android:textColor="@color/yh_text_muted"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:background="@drawable/bg_auth_card"
            android:padding="14dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="使用前须知"
                android:textColor="@color/yh_text"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="• 本应用为开源项目，仅用于管理和启动你有权使用的游戏/应用。\n• 你需要自行确认资源、账号、同步服务与第三方组件的合法性。\n• 本应用不提供游戏本体、破解资源或绕过授权的能力。\n• 第三方服务、系统权限和外部组件的可用性不由本应用保证。"
                android:textColor="@color/yh_text_muted"
                android:textSize="12sp"
                android:lineSpacingExtra="3dp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="如果你不同意以上内容，请退出应用。"
            android:textColor="#F0A64A"
            android:textSize="12sp" />

        <CheckBox
            android:id="@+id/cbDisclaimerAgree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="我已阅读并同意免责声明"
            android:textColor="@color/yh_text"
            android:textSize="13sp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="勾选后方可继续进入主界面。"
            android:textColor="@color/yh_text_muted"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnDisclaimerExit"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:background="@drawable/bg_auth_tab_inactive"
                android:foreground="?android:attr/selectableItemBackground"
                android:text="退出"
                android:textColor="@color/yh_text_muted"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnDisclaimerContinue"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:gravity="center"
                android:background="@drawable/bg_auth_button_primary"
                android:foreground="?android:attr/selectableItemBackground"
                android:alpha="0.45"
                android:text="继续"
                android:textColor="#071221"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>