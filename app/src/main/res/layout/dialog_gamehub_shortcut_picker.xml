<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="18dp"
    android:background="@drawable/bg_dialog">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="选择 GameHub 快捷方式"
        android:textColor="@color/yh_text"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvGameHubShortcutHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="可搜索游戏名、localGameId 或 steamAppId"
        android:textColor="@color/yh_text_muted"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/etGameHubShortcutSearch"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_auth_input"
        android:hint="搜索快捷方式"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:singleLine="true"
        android:textColor="@color/yh_text"
        android:textColorHint="@color/yh_text_muted"
        android:textSize="13sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerGameHubShortcuts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="4dp" />

    <Button
        android:id="@+id/btnCloseGameHubShortcutPicker"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="12dp"
        android:text="取消"
        android:textAllCaps="false" />
</LinearLayout>
