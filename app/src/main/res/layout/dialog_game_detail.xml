<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="18dp"
    android:background="@drawable/bg_dialog">

    <FrameLayout
        android:layout_width="180dp"
        android:layout_height="250dp"
        android:background="@drawable/bg_cover_placeholder">
        <ImageView
            android:id="@+id/detailCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:visibility="gone" />
        <TextView
            android:id="@+id/detailCoverPlaceholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="YH"
            android:textColor="@color/yh_text"
            android:textSize="34sp"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="18dp"
        android:orientation="vertical">

        <TextView android:id="@+id/detailTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Title" android:textColor="@color/yh_text" android:textSize="24sp" android:textStyle="bold" />
        <TextView android:id="@+id/detailInfo" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:textColor="@color/yh_text_muted" android:textSize="13sp" android:lineSpacingExtra="4dp" />
        <TextView android:id="@+id/detailPath" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:maxLines="3" android:ellipsize="middle" android:textColor="@color/yh_text_muted" android:textSize="12sp" />

        <Space android:layout_width="match_parent" android:layout_height="16dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnLaunch" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:text="启动" android:textAllCaps="false" />
            <Button android:id="@+id/btnStatus" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:layout_marginStart="8dp" android:text="标记" android:textAllCaps="false" />
            <Button android:id="@+id/btnKrSettings" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:layout_marginStart="8dp" android:text="引擎设置" android:textAllCaps="false" />
            <Button android:id="@+id/btnEdit" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:layout_marginStart="8dp" android:text="编辑" android:textAllCaps="false" />
            <Button android:id="@+id/btnDelete" android:layout_width="0dp" android:layout_weight="1" android:layout_height="42dp" android:layout_marginStart="8dp" android:text="删除" android:textAllCaps="false" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>