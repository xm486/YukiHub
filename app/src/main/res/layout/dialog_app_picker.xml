<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="18dp"
    android:background="@drawable/bg_dialog">

    <TextView
        android:id="@+id/tvAppPickerTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="选择模拟器应用"
        android:textColor="@color/yh_text"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvAppPickerHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="正在读取手机应用列表…"
        android:textColor="@color/yh_text_muted"
        android:textSize="12sp" />

    <EditText
        android:id="@+id/etAppSearch"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_auth_input"
        android:hint="搜索应用名或包名，例如 winlator"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:singleLine="true"
        android:textColor="@color/yh_text"
        android:textColorHint="@color/yh_text_muted"
        android:textSize="13sp" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerAppPicker"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:clipToPadding="false"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:id="@+id/layoutAppLoading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:indeterminate="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="加载应用中…"
                android:textColor="@color/yh_text_muted"
                android:textSize="13sp" />
        </LinearLayout>
    </FrameLayout>

    <Button
        android:id="@+id/btnCloseAppPicker"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginTop="12dp"
        android:text="取消"
        android:textAllCaps="false" />
</LinearLayout>
