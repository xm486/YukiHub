<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape>
                    <solid android:color="#273B5D8C" />
                    <corners android:radius="9dp" />
                    <stroke android:width="1dp" android:color="#7ED9F6FF" />
                </shape>
            </item>
            <item android:left="0dp" android:right="92dp" android:top="7dp" android:bottom="7dp">
                <shape>
                    <solid android:color="#D8F5FF" />
                    <corners android:radius="999dp" />
                </shape>
            </item>
            <item android:left="9dp" android:top="11dp" android:bottom="11dp" android:right="98dp">
                <shape>
                    <solid android:color="#FFFFFF" />
                    <corners android:radius="999dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#1A9BC7FF" />
            <corners android:radius="9dp" />
            <stroke android:width="1dp" android:color="#5598D9FF" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#00000000" />
            <corners android:radius="9dp" />
        </shape>
    </item>
</selector>