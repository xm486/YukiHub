<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:startColor="#E4142138"
                android:centerColor="#D9111D32"
                android:endColor="#D80D1728"
                android:angle="270" />
            <corners android:radius="10dp" />
            <stroke android:width="1dp" android:color="#467AA7D6" />
        </shape>
    </item>
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape>
            <corners android:radius="9dp" />
            <stroke android:width="1dp" android:color="#12FFFFFF" />
        </shape>
    </item>
</layer-list>
